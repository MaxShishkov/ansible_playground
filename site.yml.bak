---
- hosts: all
  become: true

  pre_tasks:
    - name: Update repo cache (CentOS)
      tags: always
      dnf:
        update_cache: yes
      changed_when: false
      when: ansible_os_family in ["RedHat", "CentOS"]

    - name: Update repo cache (Ubuntu)
      tags: always
      apt:
        update_cache: yes
      changed_when: false
      when: ansible_os_family in ["Debian", "Ubuntu"]

- hosts: all
  become: true

  tasks:
    - name: Add ssh key fro simone
      tags: alwasys
      authorized_key:
        user: simone
        state: present
        key: ""

- hosts: workstations
  become: true
  tasks:
    - name: Install unzip
      package:
        name: unzip

    - name: Install terraform
      unarchive:
        src: https://releases.hashicorp.com/terraform/1.9.5/terraform_1.9.5_linux_amd64.zip
        dest: /usr/local/bin/
        remote_src: yes
        mode: "0755"
        owner: root
        group: root

- hosts: web_servers
  become: true
  tasks:
    - name: Install Apache and PHP modules
      tags: apache,apache2,ubuntu,debian
      apt:
        name:
          - apache2
          - libapache2-mod-php
        state: latest
      when: ansible_os_family in ["Debian", "Ubuntu"]

    - name: Install apache and PHP for CentOS and RedHat
      tags: apache,centos,httpd
      dnf:
        name:
          - httpd
          - php
        state: latest
      when: ansible_os_family in ["RedHat", "CentOS"]

    - name: Start and enable apache service
      tags: apache,centos,httpd
      service:
        name: httpd
        state: started
        enabled: yes
      when: ansible_os_family in ["RedHat", "CentOS"]

    - name: Change e-mail address for admin
      tags: apache,centos,httpd
      lineinfile:
        path: /etc/httpd/conf/httpd.conf
        regexp: "^ServerAdmin"
        line: "ServerAdmin admin@example.com"
      when: ansible_os_family in ["RedHat", "CentOS"]
      register: httpd

    - name: Restart httpd (CentOS)
      tags: apache,centos,httpd
      service:
        name: httpd
        state: restarted
      when: httpd.changed

    - name: Copy default html file for site
      tags: apache,apache2,httpd
      copy:
        src: files/default_site.html
        dest: /var/www/html/index.html
        owner: root
        group: root
        mode: "0644"

- hosts: db_servers
  become: true
  tasks:
    - name: Install mariadb package
      tags: centos,db,mariadb
      dnf:
        name: mariadb
        state: latest
      when: ansible_os_family in ["RedHat", "CentOS"]

    - name: Install mariadb package Ubuntu
      tags: ubuntu,db,mariadb
      apt:
        name: mariadb-server
        state: latest
      when: ansible_os_family in ["Debian", "Ubuntu"]

- hosts: file_servers
  become: true
  tasks:
    - name: Install samba package
      tags: samba
      package:
        name: samba
        state: latest
